# AI API — v2.7.2+ 每个用户在设置页自行配置独立 Key（不再共享环境变量）
ANTHROPIC_BASE_URL=https://api.siliconflow.cn/v1
ANTHROPIC_MODEL=Qwen/Qwen3-VL-32B-Instruct

# SMTP 邮件服务 (Gmail: smtp.gmail.com, port 587, 需16位应用专用密码)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password

# NextAuth JWT 加密密钥 (openssl rand -hex 32)
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# API Key 加密密钥 (与 NEXTAUTH_SECRET 不同，必填，openssl rand -hex 32)
API_KEY_ENCRYPTION_SECRET=your_encryption_secret
