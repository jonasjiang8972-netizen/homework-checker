# Anthropic Claude API Key (https://console.anthropic.com/)
# 也可使用兼容接口（如 DeepSeek），设置 ANTHROPIC_BASE_URL
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic  # 可选：兼容接口

# Supabase 配置 (https://supabase.com/)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend 邮件服务 (https://resend.com) — 用于发送登录验证码
# SMTP (Gmail: smtp.gmail.com, port 587, 需16位应用专用密码)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
